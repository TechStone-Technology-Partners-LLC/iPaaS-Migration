<BRANCH TIMEOUT="" SWITCH="/SubmitToCredit">
  <COMMENT>===== If we do NOT submit to credit, we need to reset the status. IMPORTANT: We need to first save the transaction with InitialApplicationEntry status and then modify if necessary, NOT save it with PMR status from the beginning! =====</COMMENT>

  <!-- nodes -->

<SEQUENCE NAME="false" TIMEOUT="" EXIT-ON="FAILURE">
  <COMMENT></COMMENT>

  <!-- nodes -->

<BRANCH TIMEOUT="" LABELEXPRESSIONS="true">
