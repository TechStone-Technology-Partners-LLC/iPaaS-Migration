# ============================================================
# Migration Agent — Environment Variable Reference
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to source control.
# ============================================================


# ── Boomi (required for pull operations from Boomi source) ──────────────────
BOOMI_USERNAME=you@example.com
BOOMI_API_TOKEN=your-api-token
BOOMI_ACCOUNT_ID=your-account-id
BOOMI_TARGET_FOLDER=folder-guid-for-generated-components
BOOMI_ENVIRONMENT_ID=environment-guid
BOOMI_TEST_ATOM_ID=atom-guid


# ── Workato (required for Workato target push) ───────────────────────────────
WORKATO_API_TOKEN=your-workato-api-token
WORKATO_EMAIL=you@example.com
# Override if your account is in the AU datacenter (token starts with wrkaus-)
# WORKATO_BASE_URL=https://app.au.workato.com/api


# ── Workato PostgreSQL connection (optional, auto-creates DB connection) ──────
# WORKATO_PG_HOST=db.internal
# WORKATO_PG_PORT=5432
# WORKATO_PG_DATABASE=crm
# WORKATO_PG_USERNAME=
# WORKATO_PG_PASSWORD=
# WORKATO_PG_CONN_ID=   # Set this to skip creation and use an existing connection


# ── Oracle SOA Suite (required for oracle_soa source pull) ───────────────────
# The SOA Infrastructure Management REST API is at:
#   http://{ORACLE_SOA_HOST}:{ORACLE_SOA_PORT}/soa-infra/resources/composites
#
ORACLE_SOA_HOST=soaserver.internal        # Hostname or IP of Oracle SOA server
ORACLE_SOA_PORT=7001                      # WLS Admin / SOA-Infra port (usually 7001)
ORACLE_SOA_EM_PORT=7001                   # EM Console port (for SAR zip export; often same as SOA port)
ORACLE_SOA_USERNAME=weblogic              # WebLogic admin username
ORACLE_SOA_PASSWORD=                      # WebLogic admin password (leave blank if setting manually)
ORACLE_SOA_PARTITION=default              # Composite partition name (default: "default")


# ── Anthropic (optional, required for LLM enrichment pass) ───────────────────
# Used by enrichers/enrich_spec.py to call Claude API on complex steps.
ANTHROPIC_API_KEY=sk-ant-...


# ── Skill path override (optional) ───────────────────────────────────────────
# Set only if the boomi-integration skill is in a non-standard location.
# BOOMI_SKILL_PATH=/path/to/boomi-integration/skill
