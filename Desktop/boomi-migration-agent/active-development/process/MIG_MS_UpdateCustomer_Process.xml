              <parameters/>
              <dynamicProperties/>
            </connectoraction>
          </configuration>
          <dragpoints>
            <dragpoint name="shape4.dragpoint1" toShape="shape5" x="800.0" y="56.0"/>
          </dragpoints>
        </shape>

        <!-- Message: return success response -->
        <shape image="message_icon" name="shape5" shapetype="message" userlabel="Success Response" x="816.0" y="46.0">
          <configuration>
            <message combined="false">
              <msgTxt>'{"status": "updated"}'</msgTxt>
              <msgParameters/>
            </message>
          </configuration>
          <dragpoints>
            <dragpoint name="shape5.dragpoint1" toShape="shape6" x="992.0" y="56.0"/>
