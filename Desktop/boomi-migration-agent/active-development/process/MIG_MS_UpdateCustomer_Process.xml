  <bns:description>built with boomi-companion v1.0.0</bns:description><bns:object>
    <process allowSimultaneous="true" enableUserLog="false" processLogOnErrorOnly="false" purgeDataImmediately="false" updateRunDates="false" workload="general">
      <shapes>

        <!-- WSS Listener: POST /ws/simple/updateCustomer?id=123 with JSON body -->
        <shape image="start" name="shape1" shapetype="start" userlabel="" x="48.0" y="46.0">
          <configuration>
            <connectoraction actionType="Listen" allowDynamicCredentials="NONE" connectorType="wss" hideSettings="true" operationId="803b90c7-eb9b-45f7-9c63-145af4f820fe">
              <parameters/>
